---
import { getCollection } from 'astro:content';
import { segments } from '../../data/segments';

export async function getStaticPaths() {
  return segments.map((segment) => ({
    params: {
      segment: segment.slug,
    },
    props: {
      segment,
    },
  }));
}

const { segment } = Astro.props;

const posts = await getCollection('posts');
const segmentPosts = posts.filter(
  (post) =>
    post.data.segments.includes(segment.slug) &&
    post.data.status !== 'archived'
);
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{segment.title} | Blog Food Service</title>
    <meta name="description" content={segment.description} />
  </head>

  <body>
    <main style="font-family: Arial, sans-serif; max-width: 900px; margin: 80px auto; padding: 0 24px;">
      <a href="/blog">← Voltar para o blog</a>

      <p style="text-transform: uppercase; letter-spacing: .08em; font-size: 12px;">
        Tipo de negócio
      </p>

      <h1>{segment.title}</h1>

      <p>{segment.description}</p>

      <h2>Conteúdos relacionados</h2>

      {segmentPosts.length === 0 ? (
        <p>Ainda não há posts relacionados a este tipo de negócio.</p>
      ) : (
        <ul>
          {segmentPosts.map((post) => (
            <li>
              <a href={`/blog/${post.data.slug}`}>{post.data.title}</a>
              <p>{post.data.description}</p>
            </li>
          ))}
        </ul>
      )}
    </main>
  </body>
</html>